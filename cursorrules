## SUPABASE SCHEMA

```sql
-- Session state and full conversation history
conversations (
  id uuid primary key default gen_random_uuid(),
  session_id text not null,
  goal_tree_state jsonb not null,
  message_history jsonb not null,
  path text,
  created_at timestamptz default now(),
  updated_at timestamptz default now()
);

-- Completed published documents
drafts (
  id uuid primary key default gen_random_uuid(),
  session_id text not null,
  path text not null,
  title text not null,
  slot_content jsonb not null,
  formatted_document text not null,
  likelihood_score integer,
  existence_check_status text,
  published_at timestamptz default now()
);

-- Upvote and downvote records
votes (
  id uuid primary key default gen_random_uuid(),
  draft_id uuid references drafts(id),
  device_fingerprint text not null,
  value integer not null,
  created_at timestamptz default now(),
  unique(draft_id, device_fingerprint)
);
```

