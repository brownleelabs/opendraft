## ANTHROPIC API PATTERN

```typescript
// lib/anthropic-client.ts
import Anthropic from '@anthropic-ai/sdk';

const anthropic = new Anthropic({
  apiKey: process.env.ANTHROPIC_API_KEY
});

// Main conversation — Sonnet with prompt caching
export async function conversationCall(
  messages: { role: 'user' | 'assistant'; content: string }[],
  systemPrompt: string
): Promise<string> {
  const response = await anthropic.messages.create({
    model: 'claude-sonnet-4-6',
    max_tokens: 1000,
    system: [
      {
        type: 'text',
        text: systemPrompt,
        cache_control: { type: 'ephemeral' }  // Prompt caching — required
      }
    ],
    messages
  });
  return response.content[0].type === 'text' ? response.content[0].text : '';
}

// Classification — Haiku, fast and cheap
export async function classifyCall(
  content: string,
  instruction: string
): Promise<string> {
  const response = await anthropic.messages.create({
    model: 'claude-haiku-4-5-20251001',
    max_tokens: 100,
    system: instruction,
    messages: [{ role: 'user', content }]
  });
  return response.content[0].type === 'text' ? response.content[0].text.trim() : '';
}
```

**Prompt caching is required from day one.** The system prompt is ~4,000 tokens. Without caching that is 4,000 tokens × every message × every user. Enable it on first API call, not as an optimization later.

